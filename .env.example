# GameAnalytics Keys
# Get your keys from https://gameanalytics.com after registering your game
VITE_GA_GAME_KEY=your_game_key_here
VITE_GA_SECRET_KEY=your_secret_key_here

# Self-hosted Analytics Backend (optional, leave empty to disable)
VITE_ANALYTICS_API_URL=http://localhost:3100
VITE_ANALYTICS_API_KEY=change_me_to_a_random_string

# App version (auto-synced from package.json if omitted)
# VITE_APP_VERSION=2.1.10
